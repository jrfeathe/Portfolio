{
  "name": "portfolio-monorepo",
  "version": "1.0.3",
  "private": true,
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @portfolio/site dev",
    "lint": "pnpm --filter @portfolio/site lint",
    "test": "pnpm --filter @portfolio/site run test:coverage",
    "test:a11y": "pnpm --filter @portfolio/ui run test:a11y && pnpm --filter @portfolio/site run test:a11y",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,css}\"",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "@node-rs/jieba": "^2.0.1",
    "@portfolio/config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@types/node": "^20.11.17",
    "baseline-browser-mapping": "^2.9.18",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "kuromoji": "^0.1.2",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
}
